{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://fit5120-climatequest.onrender.com/api/$1" },
    { "source": "/", "destination": "/front.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}

