PORT=8080
NODE_ENV=development

# 前端站点地址（用于 CORS）
FRONTEND_ORIGIN=http://localhost:5500

# MySQL 连接串（Aiven MySQL）
# 例：mysql://USER:PASSWORD@HOST:PORT/DB?ssl={"rejectUnauthorized":true}
# 推荐用 MYSQL_URL；也可复用 DATABASE_URL
MYSQL_URL=

# Session 加密密钥（生产环境务必更换为强随机）
SESSION_SECRET=change-me

# 生产环境（前后端不同域）常见设置：COOKIE_SAMESITE=none
# 开启 HTTPS 时 secure=true 才能使用 SameSite=None
COOKIE_SAMESITE=lax

# 如果你的 MySQL 强制 TLS（Aiven 通常是），保持默认即可（production 会自动启用）
# MYSQL_SSL=true

# 仅在需要运维调库时设置（POST /api/admin/set-coins，请求头 X-Admin-Secret）
# 生产环境请使用足够长的随机串；不设此项则不会注册该路由
# ADMIN_SECRET=

