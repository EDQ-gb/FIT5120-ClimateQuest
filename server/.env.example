PORT=8080
NODE_ENV=development

# Frontend site URL(s) used for CORS
# Preferred (multiple): comma-separated origins
# FRONTEND_ORIGINS=http://localhost:5173,https://tp26.me,https://www.tp26.me
# Backward-compatible (single origin)
FRONTEND_ORIGIN=http://localhost:5500

# MySQL connection string (e.g. Aiven MySQL)
# Example: mysql://USER:PASSWORD@HOST:PORT/DB?ssl={"rejectUnauthorized":true}
# Prefer MYSQL_URL; DATABASE_URL is accepted as a fallback
MYSQL_URL=

# Session signing secret (use a long random value in production)
SESSION_SECRET=change-me

# Cross-site cookies: in production with separate frontend/backend domains, COOKIE_SAMESITE=none is common
# SameSite=None requires HTTPS (secure cookies)
COOKIE_SAMESITE=lax

# If your MySQL provider requires TLS, set MYSQL_SSL=true (production often enables SSL automatically)
# MYSQL_SSL=true

# Optional ops: POST /api/admin/set-coins with header X-Admin-Secret
# Use a long random secret in production; omit to disable this route
# ADMIN_SECRET=

# Optional: on each server start, set a user's coin balance (for quick cloud fixes)
# Leave unset to disable
# STARTUP_SET_COINS_USERNAME=edq
# STARTUP_SET_COINS_VALUE=999999

# Recipe model (true AI generation)
# RECIPE_MODEL_DISABLED=0
# RECIPE_PYTHON=/opt/render/project/src/server/.venv/bin/python
# RECIPE_CHECKPOINT=/opt/render/project/src/AI Development/Cooking_Dataset/best_transformer_copy_v2.pt
# RECIPE_MODEL_PERSISTENT=1
# RECIPE_MODEL_TIMEOUT_MS=20000
# RECIPE_MODEL_WARMUP_TIMEOUT_MS=90000
# RECIPE_MODEL_COOLDOWN_MS=120000
# RECIPE_MODEL_BEAM_SIZE=2
# RECIPE_MODEL_MAX_LEN=80
# RECIPE_MODEL_MIN_LEN=10

# Recipe text generation (POST /api/recipes/generate) — trained Transformer via local worker.
# Does NOT use Pollinations. See AI_WORKER_SETUP.md
# RECIPE_MODEL_PROVIDER=local_worker   # local_worker | local_builtin | disabled
# USE_RECIPE_LOCAL_WORKER=1            # alias: require LOCAL_AI_ENDPOINT or fallback
# LOCAL_AI_ENDPOINT=https://your-tunnel-url.trycloudflare.com
# AI_WORKER_TOKEN=your-secret-token
# AI_WORKER_TIMEOUT_MS=60000
# RECIPE_USE_SERVER_PYTORCH=0          # 1 = spawn PyTorch on same machine as Node (dev only)

# Remove these from Render if still set (legacy; recipe route ignores them):
# RECIPE_FAST_CLOUD_ENABLED, RECIPE_FAST_FALLBACK_TO_LOCAL, RECIPE_FAST_MODEL

# Optional legacy module only (pollinations_provider.js) — not wired to recipe route:
# RECIPE_FAST_MODEL=openai-fast
# RECIPE_FAST_TIMEOUT_MS=12000

