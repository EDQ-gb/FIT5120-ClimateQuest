PORT=8080
NODE_ENV=development

# Frontend site URL(s) used for CORS
# Preferred (multiple): comma-separated origins
# FRONTEND_ORIGINS=http://localhost:5173,https://tp26.me,https://www.tp26.me
# Backward-compatible (single origin)
FRONTEND_ORIGIN=http://localhost:5500

# MySQL connection string (e.g. Aiven MySQL)
# Example: mysql://USER:PASSWORD@HOST:PORT/DB?ssl={"rejectUnauthorized":true}
# Prefer MYSQL_URL; DATABASE_URL is accepted as a fallback
MYSQL_URL=

# Session signing secret (use a long random value in production)
SESSION_SECRET=change-me

# Cross-site cookies: in production with separate frontend/backend domains, COOKIE_SAMESITE=none is common
# SameSite=None requires HTTPS (secure cookies)
COOKIE_SAMESITE=lax

# If your MySQL provider requires TLS, set MYSQL_SSL=true (production often enables SSL automatically)
# MYSQL_SSL=true

# Optional ops: POST /api/admin/set-coins with header X-Admin-Secret
# Use a long random secret in production; omit to disable this route
# ADMIN_SECRET=

# Optional: on each server start, set a user's coin balance (for quick cloud fixes)
# Leave unset to disable
# STARTUP_SET_COINS_USERNAME=edq
# STARTUP_SET_COINS_VALUE=999999

