# Dev proxy: `/api` and `/api/recipes/*` → hosted Render API (same backend as production).
#
# Cookie login from http://127.0.0.1:5173 only works if the Render service allows that
# origin in FRONTEND_ORIGIN. To hit a local Node API instead, use gitignored
# `frontend/.env.development.local` with e.g. VITE_API_PROXY=http://127.0.0.1:8080
VITE_API_PROXY=https://fit5120-climatequest.onrender.com
VITE_RECIPE_PROXY=https://fit5120-climatequest.onrender.com
