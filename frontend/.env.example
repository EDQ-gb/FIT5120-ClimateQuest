VITE_APP_NAME=ClimateQuest

# Optional (local `npm run dev` only): copy this file to `.env.development.local` and set
# so the Vite proxy forwards `/api` to your local server instead of Render.
# VITE_API_PROXY=http://127.0.0.1:8080

# --- Vercel (Dashboard → Environment Variables), not VITE_
# Default backend for most /api/* proxies (tasks, quiz, …):
# BACKEND_BASE=https://fit5120-climatequest.onrender.com
#
# Optional: only recipe generation (`POST /api/recipes/generate`). Use when the model API
# is hosted separately from the main Node API (Python + PyTorch + .pt required).
# RECIPE_BACKEND_BASE=https://your-recipe-host.example.com
