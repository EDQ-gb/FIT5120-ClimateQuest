VITE_APP_NAME=ClimateQuest

# Committed `frontend/.env.development` points the Vite dev proxy at Render by default.
# To use a local API on :8080, add gitignored `.env.development.local` with:
# VITE_API_PROXY=http://127.0.0.1:8080
# VITE_RECIPE_PROXY=http://127.0.0.1:8080

# Local dev: recipe API (`POST /api/recipes/generate`) defaults to the dedicated Render backend.
# Point at your machine when running `server` locally with the model:
# VITE_RECIPE_PROXY=http://127.0.0.1:8080

# --- Vercel (Dashboard → Environment Variables), not VITE_
# Default backend for most /api/* proxies (tasks, quiz, …):
# BACKEND_BASE=https://fit5120-climatequest.onrender.com
#
# Recipe generation: defaults to dedicated Render service (same URL as local Vite default).
# Override only when you host the model elsewhere:
# RECIPE_BACKEND_BASE=https://fit5120-climatequest-backend.onrender.com
