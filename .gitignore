# Node
server/node_modules/
frontend/node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env / secrets
server/.env
.env
.env.*
!.env.example
# Team default: dev UI proxies to cloud API (override locally with `.env.development.local`).
!frontend/.env.development

# Build output
frontend/dist/
server/dist/
dist/

# Local handoff zips (do not commit)
_kenney_zips/

# Large unused kit files (we only commit the PNGs we reference)
frontend/public/assets/kenney_kits/**/Models/

# OS / editor
.DS_Store
Thumbs.db
.vscode/

# Handoff artifacts (avoid committing large archives)
*.tar.gz
*.tgz
*.zip

# Local Docker files (team uses cloud deployment)
docker-compose.yml
**/Dockerfile

# Root lockfile (frontend/server have their own)
/package-lock.json

# Logs / misc
*.log
.env.local

